
---
import { db, storage } from '../lib/firebase.js';
import { doc, getDoc } from 'firebase/firestore';
import { ref, listAll, getDownloadURL } from 'firebase/storage';

// Define image paths
const dianaImageUrl = '/images/diana.png';

// Contenido por defecto
const defaultContent = {
  site: { title: "Cerveceria 501" },
  header: { title: "Cerveceria 501" },
  hero: { title: "Bienvenido", subtitle: "U" },
  about: { title: "Sobre Nosotros", text: ""},
  gallery: { title: "Galería", images: [] },
  events: { title: "Eventos", list: [] },
  footer: { title: "Contacto", address: "", schedule: "", social: [] }
};

let content = defaultContent;

// --- Versión mejorada con registros de diagnóstico ---
async function getAllImageUrls(folderRef, level = 0) {
    let imageUrls = [];
    const indent = "  ".repeat(level);
    console.log(`${indent}🔍 Explorando en: ${folderRef.fullPath}`);
    
    try {
        const res = await listAll(folderRef);
        
        // Procesa los archivos en la carpeta actual
        if (res.items.length > 0) {
            console.log(`${indent}  - Encontradas ${res.items.length} imagen(es) aquí.`);
            const urlPromises = res.items.map(itemRef => getDownloadURL(itemRef));
            const urls = await Promise.all(urlPromises);
            imageUrls.push(...urls);
        } else {
            console.log(`${indent}  - No se encontraron imágenes en esta carpeta.`);
        }

        // Procesa las subcarpetas de forma recursiva
        if (res.prefixes.length > 0) {
            console.log(`${indent}  - Encontradas ${res.prefixes.length} subcarpeta(s). Analizando...`);
            for (const prefixRef of res.prefixes) {
                const subfolderUrls = await getAllImageUrls(prefixRef, level + 1);
                imageUrls.push(...subfolderUrls);
            }
        } else {
             console.log(`${indent}  - No se encontraron más subcarpetas.`);
        }

    } catch (error) {
        console.error(`${indent}❌ Error explorando ${folderRef.fullPath}:`, error);
    }
    
    if (level === 0) {
        console.log(`✅ Exploración completada. Se encontraron un total de ${imageUrls.length} imágenes.`);
    }

    return imageUrls;
}


try {
  // Fetch content from Firestore
  const docRef = doc(db, 'content', 'pageData');
  const docSnap = await getDoc(docRef);

  if (docSnap.exists()) {
    const remoteData = docSnap.data() || {};
    content = {
      site: { ...defaultContent.site, ...remoteData.site },
      header: { ...defaultContent.header, ...remoteData.header },
      hero: { ...defaultContent.hero, ...remoteData.hero },
      about: { ...defaultContent.about, ...remoteData.about },
      gallery: { ...defaultContent.gallery, ...remoteData.gallery },
      events: { ...defaultContent.events, ...remoteData.events },
      footer: { ...defaultContent.footer, ...remoteData.footer },
    };
    if (!content.events || !Array.isArray(content.events.list) || content.events.list.length === 0) {
      content.events = defaultContent.events;
    }
    if (!Array.isArray(content.footer.social)) content.footer.social = [];
  } else {
    console.log("No such document! Using default content.");
  }

  // Fetch images from Firebase Storage
  console.log("--- Iniciando la búsqueda de imágenes en Firebase Storage ---");
  const galleryRootRef = ref(storage, 'gallery');
  const imageUrls = await getAllImageUrls(galleryRootRef);
  
  if (imageUrls.length > 0) {
    content.gallery.images = imageUrls;
  }
  console.log("--- Búsqueda de imágenes finalizada. ---");

} catch (error) {
  console.error("A critical error occurred while fetching data. Using default content.", error);
  content = defaultContent;
}

// Navegación
const navItems = [
  { name: "Galería", href: "#gallery" },
  { name: "Eventos", href: "#events" },
  { name: "Contacto", href: "#contact" }
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{content.site.title}</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lobster&family=Permanent+Marker&display=swap" rel="stylesheet">
    <style define:vars={{ bgImage: `url(${dianaImageUrl})` }}>
      body {
        background-image: var(--bgImage);
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
      }
      html {
        scroll-behavior: smooth;
      }
      .font-logo { font-family: 'Lobster', cursive; }
      .font-gamberro { font-family: 'Permanent Marker', cursive; }
      .gallery-item-container {
        overflow: hidden;
        border-radius: 0.5rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        background-color: rgba(0, 0, 0, 0.5);
      }
      .gallery-image {
        width: 100%;
        height: 16rem;
        object-fit: cover;
        transition: transform 0.35s ease-in-out;
      }
      .gallery-item-container:hover .gallery-image {
        transform: scale(1.1);
      }
      #mobile-menu {
        transition: transform 0.3s ease-in-out;
      }
      .header-text-shadow {
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
      }
      .hide-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .hide-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
      }
    </style>
  </head>
  <body class="bg-black text-white font-sans">

    <div class="relative z-1">
      <!-- HEADER -->
      <header class="bg-yellow-400 bg-opacity-20 backdrop-blur-md fixed w-full z-50">
        <div class="max-w-6xl mx-auto flex items-center justify-between px-4">
          <div class="flex items-center gap-4">
            <img src="/images/logo.png" alt="Logo 501" class="h-28 w-28 rounded-full" />
            <span class="text-3xl md:text-4xl font-logo text-white tracking-wide header-text-shadow">{content.header.title}</span>
          </div>
          <nav class="hidden md:flex space-x-6 font-gamberro text-lg text-white">
            {navItems.map(item => (
              <a href={item.href} class="hover:text-yellow-400 transition-colors header-text-shadow">{item.name}</a>
            ))}
          </nav>
          <button id="menu-button" class="md:hidden text-white">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"  style="filter: drop-shadow(1px 1px 2px rgba(0,0,0,0.7));">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </header>
      
      <!-- MOBILE MENU (HIDDEN BY DEFAULT) -->
      <div id="mobile-menu" class="fixed top-0 right-0 h-full w-64 bg-black bg-opacity-90 backdrop-blur-lg z-50 transform translate-x-full">
        <nav class="flex flex-col items-center justify-center h-full space-y-8 font-gamberro text-2xl text-white">
          {navItems.map(item => (
            <a href={item.href} class="hover:text-yellow-400 transition-colors mobile-menu-link">{item.name}</a>
          ))}
        </nav>
      </div>


      <!-- HERO -->
      <main>
        <section id="hero" class="pt-32 md:pt-36 bg-black bg-opacity-50 flex flex-col items-center text-center px-4">
          <h2 class="text-5xl md:text-6xl font-gamberro text-white mb-4 md:mb-6 transition-colors hover:text-yellow-400" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.7);">
            {content.hero.title}
          </h2>
          <p class="text-lg md:text-2xl text-gray-300 mb-8 max-w-3xl">{content.hero.subtitle}</p>
          <a href="#events" class="bg-yellow-400 text-gray-900 font-gamberro text-2xl px-8 py-3 rounded-md transition-transform duration-300 hover:scale-105 hover:bg-yellow-300 shadow-lg">
            Ver Eventos
          </a>
        </section>

        <!-- ABOUT -->
        <section id="about-us" class="py-10 px-4 bg-black bg-opacity-30">
          <h3 class="text-4xl font-bold text-center mb-12 transition-colors duration-300 hover:text-yellow-400 font-gamberro">{content.about.title}</h3>
          <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-8">
            <div class="md:w-1/2">
              <img src="/images/about.jpg" alt="Sobre Nosotros" class="rounded-lg shadow-lg w-full" />
            </div>
            <div class="md:w-1/2">
              <p class="text-lg text-left transition-colors duration-300 hover:text-yellow-400">{content.about.text}</p>
            </div>
          </div>
        </section>

        <!-- GALLERY -->
        <section id="gallery" class="py-10 px-4 bg-black bg-opacity-20">
          <h3 class="text-4xl font-bold text-center mb-12 transition-colors duration-300 hover:text-yellow-400 font-gamberro">{content.gallery.title}</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {content.gallery.images.map(image => (
              <div class="gallery-item-container">
                <img src={image} alt={`Galería de ${content.site.title}`} class="gallery-image" />
              </div>
            ))}
          </div>
        </section>

        <!-- EVENTS -->
        <section id="events" class="py-10 bg-gray-900 bg-opacity-40 overflow-hidden">
          <h3 class="text-4xl font-bold text-center mb-8 transition-colors duration-300 hover:text-yellow-400 font-gamberro px-4">{content.events.title}</h3>
          <div class="flex space-x-6 md:space-x-8 overflow-x-auto pb-6 hide-scrollbar px-4 md:px-8">
            {content.events.list.map(event => (
              <div class="flex-shrink-0 w-80 md:w-96 bg-gray-800 bg-opacity-90 p-6 rounded-lg shadow-lg">
                <h4 class="text-2xl font-bold mb-2 transition-colors duration-300 hover:text-yellow-400">{event.title}</h4>
                <p class="text-yellow-400 mb-4 font-semibold">{event.schedule}</p>
                <p class="text-gray-300 transition-colors duration-300 hover:text-white">{event.description}</p>
              </div>
            ))}
          </div>
        </section>

      </main>

      <!-- FOOTER -->
      <footer id="contact" class="bg-gray-900 bg-opacity-50 py-8 px-4 text-center">
        <h3 class="text-3xl font-bold mb-4 transition-colors duration-300 hover:text-yellow-400 font-gamberro">{content.footer.title}</h3>
        <p class="mb-2 transition-colors duration-300 hover:text-yellow-400">{content.footer.address}</p>
        <p class="mb-2 transition-colors duration-300 hover:text-yellow-400">{content.footer.schedule}</p>
        <p class="mb-4">
          Síguenos en 
          {content.footer.social.map((link, index) => (
            <span key={index}>
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-yellow-400 hover:underline">{link.name}</a>
              {index < content.footer.social.length - 1 ? ' y ' : ''}
            </span>
          ))}
        </p>
      </footer>
    </div>
    <script>
      const menuButton = document.getElementById('menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuLinks = document.querySelectorAll('.mobile-menu-link');

      menuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('translate-x-full');
      });

      menuLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('translate-x-full');
        });
      });
    </script>
  </body>
</html>

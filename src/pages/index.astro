---
import { db } from '../lib/firebase.js';
import dianaImageUrl from '../../public/images/diana.png?url';

// Define a complete, default structure for the content
const defaultContent = {
  site: { title: "Mi Sitio Web" },
  header: { title: "Mi Negocio", nav: [] },
  hero: { title: "Bienvenido", subtitle: "Un subtítulo increíble", text: "Contenido sobre nosotros aquí." },
  gallery: { title: "Galería", images: [] },
  events: { title: "Eventos", list: [] },
  footer: { title: "Contacto", address: "", schedule: "", social: [] }
};

// Fetch content from Firestore
const docRef = db.collection('content').doc('pageData');
const docSnap = await docRef.get();

let content = defaultContent;

if (docSnap.exists) {
  const remoteData = docSnap.data() || {};
  // Deep merge the remote data into the default structure.
  content = {
    site: { ...defaultContent.site, ...remoteData.site },
    header: { ...defaultContent.header, ...remoteData.header },
    hero: { 
      ...defaultContent.hero, 
      ...remoteData.hero, 
      text: remoteData.about?.text || remoteData.hero?.text || defaultContent.hero.text,
    },
    gallery: { ...defaultContent.gallery, ...remoteData.gallery },
    events: { ...defaultContent.events, ...remoteData.events },
    footer: { ...defaultContent.footer, ...remoteData.footer },
  }
  // Ensure that array properties are always arrays to prevent runtime errors.
  if (!Array.isArray(content.header.nav)) content.header.nav = [];
  if (!Array.isArray(content.gallery.images)) content.gallery.images = [];
  if (!Array.isArray(content.events.list)) content.events.list = [];
  if (!Array.isArray(content.footer.social)) content.footer.social = [];
} else {
  console.log("No such document! Using default content.");
}
--- 
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{content.site.title}</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <style define:vars={{ bgImage: `url(${dianaImageUrl})` }}>
      body {
        background-image: var(--bgImage);
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
      }
    </style>
</head>
<body class="bg-black text-white font-sans">
    <div class="fixed inset-0 bg-black bg-opacity-75 z-[-1]"></div>

    <div class="relative z-1">
        <header class="p-4 flex justify-between items-center">
            <h1 class="text-2xl font-bold transition-colors duration-300 hover:text-yellow-400">{content.header.title}</h1>
            <nav>
                {content.header.nav.map(item => (
                    <a href={item.href} class="mx-2 hover:text-yellow-400 transition-colors duration-300">{item.name}</a>
                ))}
            </nav>
        </header>

        <main>
            <section id="hero" class="py-64 flex items-center justify-center text-center">
                <div>
                    <h2 class="text-6xl font-extrabold text-white transition-colors duration-300 hover:text-yellow-400" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.7);">{content.hero.title}</h2>
                    <p class="text-xl mt-4 transition-colors duration-300 hover:text-yellow-400">{content.hero.subtitle}</p>
                    <p class="max-w-3xl mx-auto text-lg text-center mt-8 transition-colors duration-300 hover:text-yellow-400">{content.hero.text}</p>
                </div>
            </section>

            <section id="gallery" class="py-20 px-4 bg-black bg-opacity-50">
                <h3 class="text-4xl font-bold text-center mb-8 transition-colors duration-300 hover:text-yellow-400">{content.gallery.title}</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    {content.gallery.images.map(image => (
                        <div class="bg-black bg-opacity-75 rounded-lg shadow-lg flex items-center justify-center">
                            <img src={image} alt={`Galería de ${content.site.title}`} class="w-full h-64 object-contain" />
                        </div>
                    ))}
                </div>
            </section>

            <section id="events" class="py-20 px-4 bg-gray-900 bg-opacity-75">
                <h3 class="text-4xl font-bold text-center mb-8 transition-colors duration-300 hover:text-yellow-400">{content.events.title}</h3>
                <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
                    {content.events.list.map(event => (
                        <div class="bg-gray-800 bg-opacity-90 p-6 rounded-lg">
                            <h4 class="text-2xl font-bold mb-2 transition-colors duration-300 hover:text-yellow-400">{event.title}</h4>
                            <p class="text-yellow-400 mb-4">{event.schedule}</p>
                            <p class="transition-colors duration-300 hover:text-yellow-400">{event.description}</p>
                        </div>
                    ))}
                </div>
            </section>
        </main>

        <footer id="contact" class="bg-gray-900 bg-opacity-75 py-10 px-4 text-center">
            <h3 class="text-3xl font-bold mb-4 transition-colors duration-300 hover:text-yellow-400">{content.footer.title}</h3>
            <p class="mb-2 transition-colors duration-300 hover:text-yellow-400">{content.footer.address}</p>
            <p class="mb-2 transition-colors duration-300 hover:text-yellow-400">{content.footer.schedule}</p>
            <p class="mb-4">
                Síguenos en 
                {content.footer.social.map((link, index) => (
                    <>
                        <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-yellow-400 hover:underline">{link.name}</a>
                        {index < content.footer.social.length - 1 && ' y '}
                    </>
                ))}
            </p>
        </footer>
    </div>
</body>
</html>